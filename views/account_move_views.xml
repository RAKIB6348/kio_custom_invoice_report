<odoo>
    <data>
        <record id="view_move_form_inherit_custom_receipt_button" model="ir.ui.view">
            <field name="name">account.move.form.custom.receipt.button</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_print_custom_receipt_invoice"
                            type="object"
                            string="Print Receipt"
                            class="btn-primary"
                            invisible="move_type not in ('out_invoice', 'out_receipt', 'out_refund')"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
